{
  "RuleName": "Autowaiver Element.Element ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "Element.Element"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "URL-Validation-Error"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "packages.element.io"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add URL-Validation-Error"
    }
  ]
}
