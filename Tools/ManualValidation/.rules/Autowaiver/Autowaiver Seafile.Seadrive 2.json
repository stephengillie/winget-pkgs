{
  "RuleName": "Autowaiver Seafile.Seadrive 2 ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "Seafile.Seadrive"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "s3.eu-central-1.amazonaws.com"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-domain"
    }
  ]
}
