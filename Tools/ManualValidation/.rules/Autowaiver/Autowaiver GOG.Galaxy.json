{
  "RuleName": "Autowaiver GOG.Galaxy ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "GOG.Galaxy"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Forbidden-URL-Error"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "cdn.gog.com"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Forbidden-URL-Error"
    }
  ]
}
