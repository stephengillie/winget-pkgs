{
  "RuleName": "Autowaiver ManticoreSoftware.Weatherbot ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "ManticoreSoftware.Weatherbot"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "files.mac-attic.com"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Domain"
    }
  ]
}
