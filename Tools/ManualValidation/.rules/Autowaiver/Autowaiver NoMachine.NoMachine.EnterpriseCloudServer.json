{
  "RuleName": "Autowaiver NoMachine.NoMachine.EnterpriseCloudServer ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "NoMachine.NoMachine.EnterpriseCloudServer"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Policy-Test-2.5"
    }
  ],
