{
  "RuleName": "Autowaiver 7zip.7zip 2 ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "7zip.7zip"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Unapproved-URL"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "sourceforge.net"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Unapproved-URL"
    }
  ]
}
