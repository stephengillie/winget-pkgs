{
  "RuleName": "Autowaiver EDPB.WebsiteAuditTool ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "EDPB.WebsiteAuditTool"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "code.europa.eu"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Domain"
    }
  ]
}
