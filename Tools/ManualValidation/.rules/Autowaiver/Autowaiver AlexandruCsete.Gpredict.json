{
  "RuleName": "Autowaiver AlexandruCsete.Gpredict ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "AlexandruCsete.Gpredict"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Unapproved-URL"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "altushost-bul.dl.sourceforge.net"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Unapproved-URL"
    }
  ]
}
