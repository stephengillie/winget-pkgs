{
  "RuleName": "Autowaiver AndyFul.ConfigureDefender ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "AndyFul.ConfigureDefender"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "raw.githubusercontent.com"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-domain"
    }
  ]
}
