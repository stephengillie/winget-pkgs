{
  "RuleName": "Autowaiver NICESoftware.AmazonDCVSessionManagerAgent ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "NICESoftware.AmazonDCVSessionManagerAgent"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "d1uj6qtbmh3dt5.cloudfront.net"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Domain"
    }
  ]
}
