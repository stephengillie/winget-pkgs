{
  "RuleName": "Autowaiver Lebo.Lebo ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "Lebo.Lebo"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "download.mirrorcast.cn"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Domain"
    }
  ]
}
