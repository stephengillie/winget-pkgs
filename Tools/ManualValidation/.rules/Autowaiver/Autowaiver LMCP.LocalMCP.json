{
  "RuleName": "Autowaiver LMCP.LocalMCP ",
  "Schedule": "Hourly",
  "Conditions": [
    {
      "Key": "PackageIdentifier",
      "Comparison": "Equals",
      "Value": "LMCP.LocalMCP"
    },
    {
      "Key": "Labels",
      "Comparison": "Match",
      "Value": "Validation-Domain"
    },
    {
      "Key": "InstallerUrl",
      "Comparison": "Equals",
      "Value": "download.local-mcp.com"
    }
  ],
  "Actions": [
    {
      "Action": "ReplyToPR",
      "Data": "@wingetbot waivers Add Validation-Domain"
    }
  ]
}
