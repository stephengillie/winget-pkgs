  {
  "RuleName": "Google.PlayGames.Beta Wrong Version",
    "Schedule": "PRWatch",
    "Conditions": [
      {
        "Key": "PackageIdentifier",
        "Comparison": "Equals",
        "Value": "Google.PlayGames.Beta"
      },
      {
        "Key": "PackageVersion",
        "Comparison": "GreaterThan",
        "Value": "120.0.0000.0"
      }
    ],
    "Actions": [
      {
        "Action": "CloseWithReason",
        "Data": "Installs a version above 120.0.0000.0 which is actually Chrome."
      }
    ]
  }